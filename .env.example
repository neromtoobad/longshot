# LONGSHOT env — copy to .env and fill in. NEVER commit .env (it is gitignored).
# RPC is NOT here: it comes from arc-canteen ($RPC). The app reads process.env.RPC.

# Testnet deployer / dev wallet (Arc testnet only — funded from faucet.circle.com)
DEPLOYER_PRIVATE_KEY=

# Circle
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Model provider (Venice)
MODEL_PROVIDER_KEY=

# Data source
ESPN_API_KEY=

# x402 seller — wallet that receives evidence data payments (platform/broker)
SELLER_ADDRESS=

# Data Broker (RFB 3) — optional. BROKER_ADDRESS defaults to SELLER_ADDRESS; markup default 2000 bps.
BROKER_ADDRESS=
BROKER_MARKUP_BPS=

# Shared runtime data dir (absolute path to <repo>/.data) so app + agent read one store.
LONGSHOT_DATA_DIR=
