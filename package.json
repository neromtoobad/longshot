{
  "name": "longshot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.18.2"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @longshot/app dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "arc:check": "pnpm --filter @longshot/shared arc:check",
    "wallet:demo": "pnpm --filter @longshot/agent wallet:demo",
    "pay:demo": "pnpm --filter @longshot/agent pay:demo",
    "broker:demo": "pnpm --filter @longshot/agent broker:demo",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0"
  }
}
