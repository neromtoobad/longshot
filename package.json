{
  "name": "longshot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.18.2"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @longshot/app dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "arc:check": "pnpm --filter @longshot/shared arc:check",
    "wallet:demo": "pnpm --filter @longshot/agent wallet:demo",
    "pay:demo": "pnpm --filter @longshot/agent pay:demo",
    "broker:demo": "pnpm --filter @longshot/agent broker:demo",
    "template:test": "pnpm --filter @longshot/agent template:test",
    "predict:test": "pnpm --filter @longshot/agent predict:test",
    "run:pool": "pnpm --filter @longshot/agent run:pool",
    "fixtures:sync": "pnpm --filter @longshot/app fixtures:sync",
    "resolve:pool": "pnpm --filter @longshot/app resolve:pool",
    "score:test": "pnpm --filter @longshot/shared score:test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed:wallets": "pnpm --filter @longshot/agent seed:wallets",
    "seed:onchain": "pnpm --filter @longshot/agent seed:onchain",
    "live:predict": "pnpm --filter @longshot/agent live:predict",
    "seed:finalize": "pnpm --filter @longshot/agent seed:finalize"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0"
  }
}
